{
  "name": "pfe",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "npx tsx src/lib/server/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "supabase:migrate": "npx supabase db push",
    "supabase:reset": "npx supabase db reset",
    "supabase:init": "npx supabase db execute --file supabase/default_updated.sql",
    "supabase:types": "npx supabase gen types typescript --local > src/lib/types/database.ts"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/aos": "^3.0.7",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.5.0",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.9",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "@sveltejs/adapter-netlify": "^6.0.4",
    "aos": "^2.3.4",
    "drizzle-orm": "^0.45.2",
    "lucide-svelte": "^1.0.1",
    "resend": "^6.12.3",
    "svelte-hamburgers": "^5.0.0",
    "svelte-meta-tags": "^4.6.0",
    "svelte-sonner": "^1.1.1",
    "svelte-switcher": "^1.0.2",
    "tippy.js": "^6.3.7",
    "zod": "^4.3.6"
  }
}
