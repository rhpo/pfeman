# === Supabase (always needed for auth, even in dev) ============
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Database Adapter ==========
# Controls which database backend is used for data queries.
#
#   "drizzle"  → SQLite via Drizzle ORM  (default when NODE_ENV != production)
#                File location controlled by DATABASE_URL (default: file:./dev.db)
#
#   "supabase" → Supabase PostgreSQL via @supabase/supabase-js
#                (default when NODE_ENV = production)
#
# DATABASE_ADAPTER=drizzle

# === SQLite file location (only used when DATABASE_ADAPTER=drizzle) ===========
# DATABASE_URL=file:./dev.db

# === Dev Auth (only used when DATABASE_ADAPTER=drizzle) =========
# HMAC key for signing the __dev_auth cookie. Any random string works.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DEV_AUTH_SECRET=change-me-to-something-random
